{
  "name": "cellitebackend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migration:generate": "ts-node ./node_modules/typeorm/cli.js migration:generate ./src/migration/init -d ./src/data-source.ts",
    "migration:run": "ts-node ./node_modules/typeorm/cli.js migration:run -d ./src/data-source.ts",
    "migration:revert": "ts-node ./node_modules/typeorm/cli.js migration:revert -d ./src/data-source.ts"
  },
  "dependencies": {
    "@sentry/node": "^7.120.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "joi": "^18.1.2",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.2",
    "reflect-metadata": "^0.2.2",
    "safer-buffer": "^2.1.2",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
